<Window x:Class="IntroSE.Kanban.Frontend.View.AddTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IntroSE.Kanban.Frontend.View"
        mc:Ignorable="d"
        Title="New Task"
        Height="360"
        Width="530"
        Background="#F9F9F9"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid>
        <Border Margin="16" Background="White" CornerRadius="8" Padding="24" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Create New Task" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Title:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Height="28" Width="340" Text="{Binding Title, Mode=OneWayToSource}" Margin="0,0,0,8"/>
                    <TextBlock Text="Description:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Top" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Height="60" Width="340" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding Description, Mode=OneWayToSource}" Margin="0,0,0,8"/>
                    <TextBlock Text="Due Date:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker Grid.Row="2" Grid.Column="1" Height="28" Width="340" SelectedDate="{Binding DueDate, Mode=OneWayToSource}"/>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Button Content="OK" Width="100" Margin="4,0" Background="#006A71" Foreground="White" FontWeight="Bold" Click="Ok_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Cancel" Width="100" Margin="4,0" Background="#333446" Foreground="White" FontWeight="Bold" Click="Cancel_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
