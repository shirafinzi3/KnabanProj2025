
<Window x:Class="IntroSE.Kanban.Frontend.View.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IntroSE.Kanban.Frontend.View"
        mc:Ignorable="d"
        Title="Login" Height="350" Width="500" Background="#F4F4F4" WindowStartupLocation="CenterScreen">

    <Grid>
        <Border Margin="20" Background="White" CornerRadius="10" Padding="20" BorderBrush="#DDDDDD" BorderThickness="1">
            <StackPanel>
                <Label Content="Welcome" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Content="Email:" 
                           Grid.Row="0" Grid.Column="0" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,5"/>
                    <TextBox Grid.Row="0" Grid.Column="1" 
                             Margin="0,0,0,5" 
                             Height="25"
                             Text="{Binding Path=Email, Mode=OneWayToSource}" />

                    <Label Content="Password:" 
                           Grid.Row="1" Grid.Column="0" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Margin="0,0,0,5"
                             Height="25"
                             Text="{Binding Path=Password, Mode=OneWayToSource}"
                             />   
                    
                   
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button Content="Login" Width="100" Margin="5,0" Background="#7F8CAA" Foreground="White" Click="Login_Click"/>
                    <Button Content="Register" Width="100" Margin="5,0" Background="#333446" Foreground="White" Click="Register_Click"/>
                </StackPanel>

                <Label Foreground="Red" 
                       Content="{Binding Path=ErrorMessage, Mode=OneWay}" 
                       HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
    

