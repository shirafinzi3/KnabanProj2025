<Window x:Class="IntroSE.Kanban.Frontend.View.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IntroSE.Kanban.Frontend.View"
        mc:Ignorable="d"
        Title="Login" Height="350" Width="500" Background="#F4F4F4" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="0"
                                Padding="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>

        <Style TargetType="TextBox" x:Key="RoundedTextBoxStyle">
            <Setter Property="Height" Value="23"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer Margin="0" x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Margin="20" Background="White" CornerRadius="10" Padding="20" BorderBrush="#DDDDDD" BorderThickness="1">
            <StackPanel>
                <Label Content="Welcome" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50" 
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Content="Email:" 
                           FontFamily="Segoe UI"
                           FontSize="13"
                           Grid.Row="0" Grid.Column="0" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,5"/>
                    <TextBox Grid.Row="0" Grid.Column="1" 
                             Style="{StaticResource RoundedTextBoxStyle}"
                             Text="{Binding Path=Email, Mode=OneWayToSource}" />

                    <Label Content="Password:" 
                           FontFamily="Segoe UI"
                           FontSize="13"
                           Grid.Row="1" Grid.Column="0" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             Text="{Binding Path=Password, Mode=OneWayToSource}" />
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Login"
                            Style="{StaticResource RoundedButtonStyle}" 
                            Background="#9ACBD0"
                            Click="Login_Click"/>
                    <Button Content="Register" 
                            Style="{StaticResource RoundedButtonStyle}" 
                            Background="#006A71"
                            Click="Register_Click"/>
                </StackPanel>

                <Label Foreground="Red" 
                       Content="{Binding Path=ErrorMessage, Mode=OneWay}" 
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
