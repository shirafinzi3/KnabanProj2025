<Window x:Class="IntroSE.Kanban.Frontend.View.BoardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding BoardName}"
        Height="600" Width="900"
        Background="#FFF9F9F9">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="⮐" FontSize="24"
                    Width="40" Height="36" Margin="0,0,8,0"
                    Background="#009899" Foreground="White" FontWeight="Bold"
                    Click="ReturnToBoards_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="Add Task"
                    Width="120" Height="36" Margin="0,0,16,0"
                    Background="#006A71" Foreground="White" FontWeight="Bold"
                    Click="AddTask_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ItemsControl Grid.Column="0" Tag="backlog" ItemsSource="{Binding BacklogTasks}">
                <ItemsControl.Template>
                    <ControlTemplate>
                        <Border Margin="8" Background="#F5F5F5" CornerRadius="6" Padding="8">
                            <DockPanel>
                                <TextBlock Text="Backlog" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,8"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8" Margin="0,0,0,8" Background="White" CornerRadius="6" BorderBrush="#DDD" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding DueDate, StringFormat={}— {0:yyyy-MM-dd}}" FontStyle="Italic" FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="→" Width="24" Height="24" Margin="8,0,0,0" Padding="0"
                                        Background="Transparent" BorderThickness="0"
                                        Tag="backlog" Click="MoveTask_Click"/>
                                <Button Grid.Column="2"
                                        Content="🗑" Width="20" Height="20" Margin="8,0,0,0" Padding="0"
                                        Background="Transparent" BorderThickness="0"
                                        Tag="backlog" Click="DeleteTask_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ItemsControl Grid.Column="1" Tag="in progress" ItemsSource="{Binding InProgressTasks}">
                <ItemsControl.Template>
                    <ControlTemplate>
                        <Border Margin="8" Background="#F5F5F5" CornerRadius="6" Padding="8">
                            <DockPanel>
                                <TextBlock Text="In Progress" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,8"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8" Margin="0,0,0,8" Background="White" CornerRadius="6" BorderBrush="#DDD" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding DueDate, StringFormat={}— {0:yyyy-MM-dd}}" FontStyle="Italic" FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="→" Width="24" Height="24" Margin="8,0,0,0" Padding="0"
                                        Background="Transparent" BorderThickness="0"
                                        Tag="in progress" Click="MoveTask_Click"/>
                                <Button Grid.Column="2"
                                        Content="🗑" Width="20" Height="20" Margin="8,0,0,0" Padding="0"
                                        Background="Transparent" BorderThickness="0"
                                        Tag="in progress" Click="DeleteTask_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ItemsControl Grid.Column="2" Tag="done" ItemsSource="{Binding DoneTasks}">
                <ItemsControl.Template>
                    <ControlTemplate>
                        <Border Margin="8" Background="#F5F5F5" CornerRadius="6" Padding="8">
                            <DockPanel>
                                <TextBlock Text="Done" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,8"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8" Margin="0,0,0,8" Background="White" CornerRadius="6" BorderBrush="#DDD" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding DueDate, StringFormat={}— {0:yyyy-MM-dd}}" FontStyle="Italic" FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="🗑" Width="20" Height="20" Margin="8,0,0,0" Padding="0"
                                        Background="Transparent" BorderThickness="0"
                                        Tag="done" Click="DeleteTask_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </DockPanel>
</Window>
