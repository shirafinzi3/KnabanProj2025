<Window x:Class="IntroSE.Kanban.Frontend.View.BoardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding BoardName}"
        Height="600"
        Width="900">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="Add Task" Width="150" Click="AddTask_Click"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="16,0,0,0"/>
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

          
            <Border Grid.Column="0" Margin="8" Background="#f5f5f5" CornerRadius="4" Padding="8"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Backlog" FontSize="18" FontWeight="Bold"/>
                    <ListBox Grid.Row="1"
                   ItemsSource="{Binding BacklogTasks}"
                   ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,0,0,8" Background="White" CornerRadius="4" BorderBrush="#ddd" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text=" — " Margin="4,0"/>
                                            <TextBlock Text="{Binding DueDate, StringFormat={}{0:yyyy-MM-dd}}" FontStyle="Italic" FontSize="12"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                            Content="→"
                            Width="24"
                            Height="24"
                            Margin="8,0,0,0"
                            Padding="0"
                            Tag="{Binding BACKLOG}"
                            Click="MoveTask_Click"/>

                                        <Button Grid.Column="2"
                            Content="✖"
                            Width="20"
                            Height="20"
                            Margin="8,0,0,0"
                            Padding="0"
                            Tag="{Binding BACKLOG}"
                            Click="DeleteTask_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

           
            <Border Grid.Column="1" Margin="8" Background="#f5f5f5" CornerRadius="4" Padding="8"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="In Progress" FontSize="18" FontWeight="Bold"/>
                    <ListBox Grid.Row="1"
                   ItemsSource="{Binding InProgressTasks}"
                   ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,0,0,8" Background="White" CornerRadius="4" BorderBrush="#ddd" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text=" — " Margin="4,0"/>
                                            <TextBlock Text="{Binding DueDate, StringFormat={}{0:yyyy-MM-dd}}" FontStyle="Italic" FontSize="12"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                            Content="→"
                            Width="24"
                            Height="24"
                            Margin="8,0,0,0"
                            Padding="0"
                            Tag="{Binding IN_PROGRESS}"
                            Click="MoveTask_Click"/>

                                        <Button Grid.Column="2"
                            Content="✖"
                            Width="20"
                            Height="20"
                            Margin="8,0,0,0"
                            Padding="0"
                            Tag="{Binding IN_PROGRESS}"
                            Click="DeleteTask_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

           
            <Border Grid.Column="2" Margin="8" Background="#f5f5f5" CornerRadius="4" Padding="8"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Done" FontSize="18" FontWeight="Bold"/>
                    <ListBox Grid.Row="1"
                   ItemsSource="{Binding DoneTasks}"
                   ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,0,0,8" Background="White" CornerRadius="4" BorderBrush="#ddd" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text=" — " Margin="4,0"/>
                                            <TextBlock Text="{Binding DueDate, StringFormat={}{0:yyyy-MM-dd}}" FontStyle="Italic" FontSize="12"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                            Content="✖"
                            Width="20"
                            Height="20"
                            Margin="8,0,0,0"
                            Padding="0"
                            Tag="{Binding DONE}"
                            Click="DeleteTask_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

        </Grid>
    </DockPanel>
</Window>
